---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Preguntas Frecuentes - Jose Ale & Sansta">
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <main class="page-content">
    <h1 class="page-title">P R E G U N T A S</h1>

    <div class="faq-list">
      <div class="faq-item">
        <h3 class="faq-question">¿Cuál es el código de vestimenta?</h3>
        <p class="faq-answer">
          Formal / Etiqueta rigurosa. Sugerimos vestidos largos para las mujeres
          y traje oscuro o esmoquin para los hombres.
        </p>
      </div>

      <div class="faq-item">
        <h3 class="faq-question">¿Puedo llevar un acompañante (+1)?</h3>
        <p class="faq-answer">
          Si su invitación indica "y acompañante", por favor siéntase libre de
          traer a alguien. Si no es así, le pedimos que asista solo ya que el
          evento es íntimo.
        </p>
      </div>

      <div class="faq-item">
        <h3 class="faq-question">¿A qué hora debo llegar a la ceremonia?</h3>
        <p class="faq-answer">
          Recomendamos llegar al menos 30 minutos antes de las 3:30 pm para
          encontrar su asiento antes de que comience la ceremonia.
        </p>
      </div>
    </div>

    <div class="separator-small">
      <svg
        viewBox="0 0 40 40"
        width="30"
        height="30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <footer class="mini-footer">
      <div class="heart-logo">
        <span class="names-logo">J&S</span>
        <svg
          viewBox="0 0 40 20"
          width="30"
          height="15"
          fill="none"
          stroke="var(--text-accent)"
          stroke-width="2"
          style="margin-left: 5px;">
          <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
          ></path>
        </svg>
      </div>
      <p class="tagline">Para todos los días en el camino.</p>

      <nav class="footer-nav">
        <a href="/">Inicio</a>
        <a href="/faqs">Preguntas Frecuentes</a>
        <a href="#">Contacto</a>
      </nav>

      <p class="credits">josealeysansta@email.com</p>
    </footer>
  </main>
</Layout>

<style>
  .page-content {
    max-width: 700px;
    margin: 0 auto;
    padding: 100px 20px 40px;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 50px;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 35px;
  }

  .faq-item {
    border-bottom: 1px solid #ebebeb;
    padding-bottom: 25px;
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    font-family: var(--font-heading);
    color: var(--text-primary);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .faq-answer {
    font-family: var(--font-body);
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Base footer replacement for inner pages */
  .separator-small {
    margin: 40px auto 30px;
    text-align: center;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 20px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
