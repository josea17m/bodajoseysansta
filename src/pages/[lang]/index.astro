---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("home.hero.names") + " - " + t("home.hero.date")}>
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <section class="hero-carousel" id="heroCarousel">
    <div
      class="carousel-slide active"
      style="background-image: url('/images/venue.png')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('/images/ring.png')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=2000&auto=format&fit=crop')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2000&auto=format&fit=crop')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=2000&auto=format&fit=crop')">
    </div>
  </section>

  <main class="content">
    <section class="names-section relative py-12">
      <h1
        class="names drop-shadow-sm font-serif text-5xl md:text-6xl text-[#c4917c] tracking-widest flex flex-col items-center mb-6">
        <span class="name">{t("home.hero.names")}</span>
        <span class="ampersand text-2xl my-4 text-gray-400 font-light"
          >{t("home.hero.and")}</span
        >
        <span class="name">{t("home.hero.sansta")}</span>
      </h1>
      <p class="hashtag font-serif italic text-gray-500 text-xl mb-10">
        {t("home.hero.hashtag")}
      </p>

      <div
        class="inline-block border-y border-gray-200 py-6 px-12 mb-8 bg-[#faf9f6]/50 rounded-lg shadow-sm">
        <h2
          class="date font-serif text-[#c4917c] text-2xl md:text-3xl tracking-[0.2em] mb-4 uppercase">
          {t("home.hero.date")}
        </h2>
        <p
          class="location-short text-gray-700 tracking-wider text-sm md:text-base uppercase">
          {t("home.hero.location")}
        </p>
      </div>

      <div class="countdown" id="countdown">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <section
      class="venue-section bg-white p-8 rounded-xl shadow-[0_4px_20px_-4px_rgba(0,0,0,0.05)] border border-gray-100 relative overflow-hidden">
      <!-- Decorative corner accents -->
      <div
        class="absolute top-0 left-0 w-8 h-8 border-t border-l border-[#c4917c]/30">
      </div>
      <div
        class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-[#c4917c]/30">
      </div>

      <h3
        class="section-title text-[#c4917c] font-serif tracking-[0.25em] text-xl mb-6 uppercase">
        {t("home.venue.ceremony.title")}
      </h3>
      <p class="venue-name font-semibold text-lg text-gray-800 mb-2">
        {t("home.venue.ceremony.name")}
      </p>
      <p class="venue-address text-gray-500 leading-relaxed">
        19220 Beechnut St Hall A<br />Richmond, TX 77407
      </p>

      <div class="h-12 flex justify-center items-center">
        <span class="w-12 h-px bg-gray-200 block"></span>
      </div>

      <h3
        class="section-title text-[#c4917c] font-serif tracking-[0.25em] text-xl mb-6 uppercase">
        {t("home.venue.reception.title")}
      </h3>
      <p class="venue-name font-semibold text-lg text-gray-800 mb-2">
        {t("home.venue.reception.name")}
      </p>
      <p class="venue-address text-gray-500 leading-relaxed">
        1001 W 18th St<br />Houston, TX 77008
      </p>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <section class="story-section pb-10">
      <h3
        class="section-title text-[#c4917c] font-serif tracking-[0.25em] text-2xl mb-8 uppercase">
        {t("home.story.title")}
      </h3>
      <div
        class="story-text text-gray-600 leading-loose text-justify max-w-lg mx-auto font-body space-y-6">
        <p
          class="first-letter:text-5xl first-letter:font-serif first-letter:text-[#c4917c] first-letter:mr-3 first-letter:float-left">
          {t("home.story.p1")}
        </p>
        <p>
          {t("home.story.p2")}
        </p>
      </div>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>
  </main>

  <footer
    class="mini-footer bg-[#faf9f6]/80 mt-16 pt-12 pb-16 flex flex-col items-center gap-6 border-t border-gray-100">
    <div class="heart-logo flex items-center justify-center mb-2">
      <span
        class="names-logo font-serif text-2xl tracking-widest text-[#c4917c]"
        >J&S</span
      >
      <svg
        viewBox="0 0 40 20"
        width="30"
        height="15"
        fill="none"
        stroke="#c4917c"
        stroke-width="1.5"
        class="ml-2 opacity-60">
        <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
        ></path>
      </svg>
    </div>
    <p
      class="tagline text-gray-400 italic font-serif tracking-widest text-sm uppercase">
      {t("footer.tagline")}
    </p>

    <nav class="footer-nav flex gap-8 justify-center my-4">
      <a
        href={translatePath("/gallery")}
        class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
        >{t("nav.gallery")}</a
      >
      <a
        href={translatePath("/faqs")}
        class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
        >{t("nav.faqs")}</a
      >
      <a
        href={translatePath("/schedule")}
        class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
        >{t("nav.schedule")}</a
      >
    </nav>

    <div class="text-center mt-4">
      <p class="credits text-xs text-gray-400 mb-2">josealeysansta@email.com</p>
      <p class="credits text-xs text-gray-300">
        © 2026 Jose Ale & Sansta. {t("footer.rights")}
      </p>
    </div>
  </footer>
</Layout>

<script
  define:vars={{
    countdownTranslations: {
      ready: t("home.countdown.ready"),
      days: t("home.countdown.days"),
      hours: t("home.countdown.hours"),
      minutes: t("home.countdown.minutes"),
      seconds: t("home.countdown.seconds"),
    },
  }}
>
  document.addEventListener("DOMContentLoaded", () => {
    const countdownElement = document.getElementById("countdown");
    if (!countdownElement) return;

    // July 24, 2026 at 15:30 (3:30 PM)
    const weddingDate = new Date("2026-07-24T15:30:00").getTime();

    // Carousel Logic
    const slides = document.querySelectorAll(".carousel-slide");
    if (slides.length > 0) {
      let currentSlide = 0;
      setInterval(() => {
        if (slides[currentSlide]) {
          slides[currentSlide].classList.remove("active");
        }
        currentSlide = (currentSlide + 1) % slides.length;
        if (slides[currentSlide]) {
          slides[currentSlide].classList.add("active");
        }
      }, 4000); // Change image every 4 seconds
    }

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = weddingDate - now;

      if (!countdownElement) return;

      if (distance < 0) {
        countdownElement.innerHTML = `<span class="text-xl font-serif text-[#c4917c]">${countdownTranslations.ready}</span>`;
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor(
        (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
      );
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      countdownElement.innerHTML = `
                <div class="flex gap-6 justify-center text-gray-600 font-serif mt-2">
                  <div class="flex flex-col items-center"><span class="text-3xl font-medium text-[#c4917c] mb-1">${days}</span><span class="text-xs tracking-widest text-gray-400 uppercase">${countdownTranslations.days}</span></div>
                  <div class="flex flex-col items-center"><span class="text-3xl font-medium text-[#c4917c] mb-1">${hours}</span><span class="text-xs tracking-widest text-gray-400 uppercase">${countdownTranslations.hours}</span></div>
                  <div class="flex flex-col items-center"><span class="text-3xl font-medium text-[#c4917c] mb-1">${minutes}</span><span class="text-xs tracking-widest text-gray-400 uppercase">${countdownTranslations.minutes}</span></div>
                  <div class="flex flex-col items-center"><span class="text-3xl font-medium text-[#c4917c] mb-1">${seconds}</span><span class="text-xs tracking-widest text-gray-400 uppercase">${countdownTranslations.seconds}</span></div>
                </div>
            `;
    }

    setInterval(updateCountdown, 1000);
    updateCountdown();
  });
</script>

<style>
  /* Hero Carousel */
  .hero-carousel {
    position: relative;
    width: 100vw;
    height: 45vh;
    min-height: 400px;
    max-height: 600px;
    overflow: hidden;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    z-index: 1;
  }

  .carousel-slide.active {
    opacity: 1;
    z-index: 2;
  }

  /* Main Content Wrapper */
  .content {
    max-width: 800px;
    margin: 0 auto;
    padding: 60px 20px;
    text-align: center;
  }

  /* Names Section */
  .names-section {
    margin-bottom: 50px;
  }

  .names {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 2.8rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 25px;
  }

  .ampersand {
    font-size: 1.2rem;
    margin: 15px 0;
  }

  .hashtag {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--text-meta);
    font-size: 1.2rem;
    margin-bottom: 40px;
  }

  .date {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.6rem;
    letter-spacing: 0.18em;
    margin-bottom: 20px;
  }

  .location-short {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 35px;
    letter-spacing: 0.05em;
  }

  .countdown {
    font-size: 0.95rem;
    color: var(--text-meta);
    letter-spacing: 0.05em;
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .countdown :global(span) {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }

  .countdown :global(.time-val) {
    font-weight: 500;
  }

  /* Separator */
  .separator {
    text-align: center;
    margin: 50px 0;
  }

  .separator svg {
    margin: 0 auto;
  }

  /* Generic Section Styles */
  .section-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.4rem;
    letter-spacing: 0.25em;
    margin-bottom: 25px;
    text-transform: uppercase;
  }

  /* Venue Section */
  .venue-name {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .venue-address {
    color: var(--text-meta);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Story Section */
  .story-text {
    color: var(--text-primary);
    font-size: 1rem;
    line-height: 1.9;
    text-align: justify;
    max-width: 500px;
    margin: 0 auto;
  }

  .story-text p {
    margin-bottom: 25px;
  }

  /* Base footer replacement for inner pages */
  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding: 40px 20px 60px;
    border-top: 1px solid #eee;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
