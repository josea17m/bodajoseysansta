---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("schedule.title") + " - Jose Ale & Sansta"}>
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <main class="page-content">
    <h1 class="page-title">{t("schedule.title")}</h1>
    <p class="schedule-intro">
      {t("schedule.intro")}
    </p>

    <h2 class="schedule-date">{t("schedule.date")}</h2>

    <div class="event-divider">
      <svg
        viewBox="0 0 40 20"
        width="40"
        height="20"
        fill="none"
        stroke="var(--text-meta)"
        stroke-width="1">
        <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
        ></path>
      </svg>
    </div>

    <section class="event-section">
      <h3 class="event-title">{t("home.venue.ceremony.title")}</h3>
      <p class="event-time">3:30 pm</p>
      <p class="event-venue">{t("home.venue.ceremony.name")}</p>
      <p class="event-address">
        <a
          href="https://maps.google.com/?q=19220+Beechnut+St+Hall+A,+Richmond,+TX+77407"
          target="_blank"
          class="address-link">19220 Beechnut St Hall A, Richmond, TX 77407</a
        >
      </p>
      <div class="event-actions">
        <a
          href="https://maps.google.com/?q=19220+Beechnut+St+Hall+A,+Richmond,+TX+77407"
          target="_blank"
          class="btn-action">{t("schedule.map")}</a
        >
      </div>
    </section>

    <div class="event-divider">
      <svg
        viewBox="0 0 40 20"
        width="40"
        height="20"
        fill="none"
        stroke="var(--text-meta)"
        stroke-width="1">
        <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
        ></path>
      </svg>
    </div>

    <section class="event-section">
      <h3 class="event-title">{t("home.venue.reception.title")}</h3>
      <p class="event-time">5:30 pm</p>
      <p class="event-venue">{t("home.venue.reception.name")}</p>
      <p class="event-address">
        <a
          href="https://maps.google.com/?q=1001+W+18th+St,+Houston,+TX+77008"
          target="_blank"
          class="address-link">1001 W 18th St, Houston, TX 77008</a
        >
      </p>
      <div class="event-actions">
        <a
          href="https://maps.google.com/?q=1001+W+18th+St,+Houston,+TX+77008"
          target="_blank"
          class="btn-action">{t("schedule.map")}</a
        >
      </div>
    </section>

    <div class="separator-small">
      <svg
        viewBox="0 0 40 40"
        width="30"
        height="30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <!-- Custom Footer specifically without Zola but following the layout -->
    <footer class="mini-footer">
      <div class="heart-logo">
        <span class="names-logo">J&S</span>
        <svg
          viewBox="0 0 40 20"
          width="30"
          height="15"
          fill="none"
          stroke="var(--text-accent)"
          stroke-width="2"
          style="margin-left: 5px;">
          <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
          ></path>
        </svg>
      </div>
      <p class="tagline">{t("footer.tagline")}</p>

      <nav class="footer-nav">
        <a href={translatePath("/")}>{t("nav.home")}</a>
        <a href={translatePath("/faqs")}>{t("nav.faqs")}</a>
        <a href={translatePath("/registry")}>{t("nav.registry")}</a>
      </nav>

      <p class="credits">josealeysansta@email.com</p>
    </footer>
  </main>
</Layout>

<style>
  .header {
    padding: 20px;
    display: flex;
    justify-content: flex-start;
  }

  .menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: var(--text-accent);
  }

  .page-content {
    max-width: 600px;
    margin: 0 auto;
    padding: 100px 20px 40px;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 25px;
  }

  .schedule-intro {
    font-family: var(--font-body);
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 40px;
  }

  .schedule-date {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.4rem;
    letter-spacing: 0.2em;
    margin-bottom: 30px;
    text-transform: uppercase;
  }

  .event-divider {
    margin: 30px 0;
  }

  .event-section {
    margin-bottom: 40px;
  }

  .event-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.2rem;
    letter-spacing: 0.25em;
    margin-bottom: 10px;
  }

  .event-time {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text-meta);
    margin-bottom: 20px;
  }

  .event-venue {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-bottom: 5px;
  }

  .event-address {
    margin-bottom: 25px;
  }

  .address-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-style: italic;
    color: #6c7a65; /* A bit of olive green for the link */
    text-decoration: underline;
    text-decoration-color: #6c7a65;
    text-underline-offset: 3px;
  }

  .event-actions {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
  }

  .btn-action {
    display: inline-block;
    width: 100%;
    max-width: 280px;
    padding: 12px 0;
    background-color: #6c7a65; /* Olive green from the reference */
    color: white;
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .btn-action:hover {
    background-color: #5a6654;
  }

  /* Base footer replacement for inner pages */
  .separator-small {
    margin: 60px 0 40px;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 20px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
