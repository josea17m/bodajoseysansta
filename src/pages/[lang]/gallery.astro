---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("gallery.title") + " - Jose Ale & Sansta"}>
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <main class="page-content">
    <h1 class="page-title">{t("gallery.title")}</h1>

    <div class="gallery-grid">
      <!-- Placeholders for gallery photos (to be replaced with actual image files if provided later) -->
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x500/?couple,wedding"
          alt="Gallery Image 1"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x400/?couple,love"
          alt="Gallery Image 2"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x600/?couple,happy"
          alt="Gallery Image 3"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x450/?couple,hug"
          alt="Gallery Image 4"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x550/?couple,kiss"
          alt="Gallery Image 5"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x400/?couple,smile"
          alt="Gallery Image 6"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x600/?couple,romance"
          alt="Gallery Image 7"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x500/?couple,nature"
          alt="Gallery Image 8"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x450/?couple,portrait"
          alt="Gallery Image 9"
          loading="lazy"
        />
      </div>
      <div class="gallery-item">
        <img
          src="https://source.unsplash.com/random/400x400/?couple,travel"
          alt="Gallery Image 10"
          loading="lazy"
        />
      </div>
    </div>

    <div class="separator-small">
      <svg
        viewBox="0 0 40 40"
        width="30"
        height="30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <!-- Custom Footer specifically without Zola but following the layout -->
    <footer class="mini-footer">
      <div class="heart-logo">
        <span class="names-logo">J&S</span>
        <svg
          viewBox="0 0 40 20"
          width="30"
          height="15"
          fill="none"
          stroke="var(--text-accent)"
          stroke-width="2"
          style="margin-left: 5px;">
          <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
          ></path>
        </svg>
      </div>
      <p class="tagline">{t("footer.tagline")}</p>

      <nav class="footer-nav">
        <a href={translatePath("/")}>{t("nav.home")}</a>
        <a href={translatePath("/faqs")}>{t("nav.faqs")}</a>
        <a href={translatePath("/schedule")}>{t("nav.schedule")}</a>
        <a href={translatePath("/registry")}>{t("nav.registry")}</a>
      </nav>

      <p class="credits">josealeysansta@email.com</p>
    </footer>
  </main>
</Layout>

<style>
  .header {
    padding: 20px;
    display: flex;
    justify-content: flex-start;
  }

  .menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: var(--text-accent);
  }

  .page-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 100px 20px 60px;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 40px;
  }

  .gallery-grid {
    display: flex;
    flex-direction: column;
    gap: 15px;
    max-width: 500px;
    margin: 0 auto;
  }

  .gallery-item {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
  }

  .gallery-item img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .gallery-item:hover img {
    transform: scale(1.02);
  }

  .separator-small {
    margin: 40px 0 20px;
  }

  .names-bottom {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--text-primary);
    font-size: 1.2rem;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 40px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
