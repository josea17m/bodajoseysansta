---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("faqs.title") + " - Jose Ale & Sansta"}>
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <main class="page-content">
    <h1 class="page-title">{t("faqs.title")}</h1>

    <p class="faqs-intro">
      {t("faqs.intro")}
    </p>

    <div class="faq-list">
      <div class="faq-item">
        <h3 class="faq-question">{t("faq.q1")}</h3>
        <p class="faq-answer">
          {t("faq.a1")}
        </p>
      </div>

      <div class="faq-item">
        <h3 class="faq-question">{t("faq.q2")}</h3>
        <p class="faq-answer">
          {t("faq.a2")}
        </p>
      </div>

      <div class="faq-item">
        <h3 class="faq-question">{t("faq.q3")}</h3>
        <p class="faq-answer">
          {t("faq.a3")}
        </p>
      </div>
    </div>

    <div class="separator-small">
      <svg
        viewBox="0 0 40 40"
        width="30"
        height="30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <footer class="mini-footer">
      <div class="heart-logo">
        <span class="names-logo">J&S</span>
        <svg
          viewBox="0 0 40 20"
          width="30"
          height="15"
          fill="none"
          stroke="var(--text-accent)"
          stroke-width="2"
          style="margin-left: 5px;">
          <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
          ></path>
        </svg>
      </div>

      <nav class="footer-nav">
        <a href={translatePath("/")}>{t("nav.home")}</a>
        <a href={translatePath("/gallery")}>{t("nav.gallery")}</a>
        <a href={translatePath("/schedule")}>{t("nav.schedule")}</a>
        <a href={translatePath("/registry")}>{t("nav.registry")}</a>
      </nav>

      <p class="credits">josealeysansta@email.com</p>
    </footer>
  </main>
</Layout>

<style>
  .header {
    padding: 20px;
    display: flex;
    justify-content: flex-start;
  }

  .menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: var(--text-accent);
  }

  .page-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 25px;
  }

  .faqs-intro {
    font-family: var(--font-body);
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 50px;
  }

  .faq-list {
    text-align: left;
    max-width: 600px;
    margin: 0 auto;
  }

  .faq-item {
    margin-bottom: 30px;
  }

  .faq-question {
    font-family: var(--font-heading);
    color: var(--text-primary);
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 10px;
  }

  .faq-answer {
    color: var(--text-meta);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Base footer replacement for inner pages */
  .separator-small {
    margin: 60px 0 40px;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 20px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
