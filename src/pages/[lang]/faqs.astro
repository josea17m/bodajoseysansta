---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("faqs.title") + " - Jose Ale & Sansta"}>
  <div class="page-container min-h-screen bg-[#faf9f6]">
    <header
      class="header flex justify-between items-center p-6 bg-transparent absolute w-full z-10">
      <button class="menu-btn p-2" aria-label="Menú">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#c4917c"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </header>

    <main class="page-content max-w-3xl mx-auto pt-32 pb-16 px-6 text-center">
      <h1
        class="page-title font-serif text-3xl md:text-4xl text-[#c4917c] tracking-[0.2em] mb-8">
        {t("faqs.title")}
      </h1>

      <p
        class="faqs-intro text-gray-600 font-body leading-relaxed mb-16 max-w-2xl mx-auto">
        {t("faqs.intro")}
      </p>

      <div class="faq-list space-y-8 max-w-2xl mx-auto text-left">
        <div
          class="faq-item bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <h3 class="faq-question font-serif text-[#c4917c] text-lg mb-3">
            {t("faq.q1")}
          </h3>
          <p class="faq-answer text-gray-600 leading-relaxed">{t("faq.a1")}</p>
        </div>

        <div
          class="faq-item bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <h3 class="faq-question font-serif text-[#c4917c] text-lg mb-3">
            {t("faq.q2")}
          </h3>
          <p class="faq-answer text-gray-600 leading-relaxed">{t("faq.a2")}</p>
        </div>

        <div
          class="faq-item bg-white p-6 md:p-8 rounded-xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
          <h3 class="faq-question font-serif text-[#c4917c] text-lg mb-3">
            {t("faq.q3")}
          </h3>
          <p class="faq-answer text-gray-600 leading-relaxed">{t("faq.a3")}</p>
        </div>
      </div>

      <footer class="mini-footer mt-20 pt-10 border-t border-[#c4917c]/20">
        <nav class="footer-nav flex justify-center gap-6 mb-6">
          <a
            href={translatePath("/")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.home")}</a
          >
          <a
            href={translatePath("/gallery")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.gallery")}</a
          >
          <a
            href={translatePath("/schedule")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.schedule")}</a
          >
          <a
            href={translatePath("/registry")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.registry")}</a
          >
        </nav>

        <p class="credits text-xs text-gray-400">josealeysansta@email.com</p>
      </footer>
    </main>
  </div>
</Layout>

<style>
  .page-content {
    max-width: 700px;
    margin: 0 auto;
    padding: 100px 20px 40px;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 50px;
    text-align: center;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 35px;
  }

  .faq-item {
    border-bottom: 1px solid #ebebeb;
    padding-bottom: 25px;
  }

  .faq-item:last-child {
    border-bottom: none;
  }

  .faq-question {
    font-family: var(--font-heading);
    color: var(--text-primary);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .faq-answer {
    font-family: var(--font-body);
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Base footer replacement for inner pages */
  .separator-small {
    margin: 40px auto 30px;
    text-align: center;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 20px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
