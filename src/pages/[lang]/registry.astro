---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("registry.title") + " - Jose Ale & Sansta"}>
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <main class="page-content">
    <h1 class="page-title">{t("registry.title")}</h1>
    <p class="registry-intro">
      {t("registry.intro1")}
      <br /><br />
      {t("registry.intro2")}
    </p>

    <section class="registry-section">
      <h2 class="registry-name">{t("registry.bank")}</h2>
      <p
        style="color: var(--text-meta); font-size: 0.95rem; margin-bottom: 25px; line-height: 1.6;">
        {t("registry.bank.name")}<br />
        {t("registry.bank.clabe")}<br />
        {t("registry.bank.bankName")}
      </p>
    </section>

    <section class="registry-section">
      <h2 class="registry-name">{t("registry.amazon")}</h2>
      <p
        style="color: var(--text-meta); font-size: 0.95rem; margin-bottom: 25px;">
        {t("registry.amazon.desc")}
      </p>
      <a href="#" class="btn-action">Ver mesa de regalos</a>
    </section>

    <div class="separator-small">
      <svg
        viewBox="0 0 40 40"
        width="30"
        height="30"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <!-- Custom Footer specifically without Zola but following the layout -->
    <footer class="mini-footer">
      <div class="heart-logo">
        <span class="names-logo">J&S</span>
        <svg
          viewBox="0 0 40 20"
          width="30"
          height="15"
          fill="none"
          stroke="var(--text-accent)"
          stroke-width="2"
          style="margin-left: 5px;">
          <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
          ></path>
        </svg>
      </div>

      <nav class="footer-nav">
        <a href={translatePath("/")}>{t("nav.home")}</a>
        <a href={translatePath("/gallery")}>{t("nav.gallery")}</a>
        <a href={translatePath("/faqs")}>{t("nav.faqs")}</a>
        <a href={translatePath("/schedule")}>{t("nav.schedule")}</a>
      </nav>

      <p class="credits">josealeysansta@email.com</p>
    </footer>
  </main>
</Layout>

<style>
  .header {
    padding: 20px;
    display: flex;
    justify-content: flex-start;
  }

  .menu-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    color: var(--text-accent);
  }

  .page-content {
    max-width: 600px;
    margin: 0 auto;
    padding: 100px 20px 40px;
    text-align: center;
  }

  .page-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.8rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    margin-bottom: 25px;
  }

  .registry-intro {
    font-family: var(--font-body);
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 50px;
  }

  .registry-section {
    margin-bottom: 40px;
  }

  .registry-name {
    font-family: var(--font-heading);
    color: var(--text-primary);
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }

  .btn-action {
    display: inline-block;
    width: 100%;
    max-width: 280px;
    padding: 14px 0;
    background-color: #6c7a65; /* Olive green */
    color: white;
    text-decoration: none;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1rem;
    border-radius: 4px;
    transition: background-color 0.2s ease;
  }

  .btn-action:hover {
    background-color: #5a6654;
  }

  /* Base footer replacement for inner pages */
  .separator-small {
    margin: 60px 0 40px;
  }

  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding-top: 20px;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
