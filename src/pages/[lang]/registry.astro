---
import Layout from "../../layouts/Layout.astro";
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from "../../i18n/utils";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
---

<Layout title={t("registry.title") + " - Jose Ale & Sansta"}>
  <div class="page-container min-h-screen bg-[#faf9f6]">
    <header
      class="header flex justify-between items-center p-6 bg-transparent absolute w-full z-10">
      <button class="menu-btn p-2" aria-label="Menú">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="28"
          height="28"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#c4917c"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </header>

    <main class="page-content max-w-3xl mx-auto pt-32 pb-16 px-6 text-center">
      <h1
        class="page-title font-serif text-3xl md:text-4xl text-[#c4917c] tracking-[0.2em] mb-8">
        {t("registry.title")}
      </h1>

      <div
        class="registry-intro text-gray-600 font-body leading-relaxed mb-16 max-w-2xl mx-auto space-y-4">
        <p>{t("registry.intro1")}</p>
        <p>{t("registry.intro2")}</p>
      </div>

      <div class="registry-options grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Bank Option -->
        <div
          class="registry-card bg-white p-10 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center relative overflow-hidden group hover:shadow-md transition-shadow">
          <div
            class="absolute top-0 right-0 w-16 h-16 bg-[#faf9f6] rounded-bl-full -z-0">
          </div>
          <svg
            class="w-10 h-10 text-[#c4917c] mb-6 z-10"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"
            ></path>
          </svg>
          <h3
            class="bank-title font-serif tracking-widest text-lg text-gray-800 mb-6 z-10">
            {t("registry.bank")}
          </h3>
          <div class="bank-details text-gray-500 space-y-3 z-10">
            <p>{t("registry.bank.name")}</p>
            <p
              class="font-mono text-sm bg-gray-50 px-3 py-2 rounded text-gray-600 select-all">
              {t("registry.bank.clabe")}
            </p>
            <p>{t("registry.bank.bankName")}</p>
          </div>
        </div>

        <!-- Amazon Option -->
        <div
          class="registry-card bg-white p-10 rounded-xl shadow-sm border border-gray-100 flex flex-col items-center relative overflow-hidden group hover:shadow-md transition-shadow">
          <div
            class="absolute top-0 right-0 w-16 h-16 bg-[#faf9f6] rounded-bl-full -z-0">
          </div>
          <svg
            class="w-10 h-10 text-[#c4917c] mb-6 z-10"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
            ></path>
          </svg>
          <h3
            class="amazon-title font-serif tracking-widest text-lg text-gray-800 mb-6 z-10">
            {t("registry.amazon")}
          </h3>
          <p class="amazon-desc text-gray-500 mb-8 z-10">
            {t("registry.amazon.desc")}
          </p>
          <a
            href="#"
            class="amazon-btn inline-block border border-[#c4917c] text-[#c4917c] uppercase tracking-widest text-xs px-8 py-3 rounded-full hover:bg-[#c4917c] hover:text-white transition-all z-10">
            Ver Mesa en Amazon
          </a>
        </div>
      </div>

      <footer class="mini-footer mt-20 pt-10 border-t border-[#c4917c]/20">
        <nav class="footer-nav flex justify-center gap-6 mb-6">
          <a
            href={translatePath("/")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.home")}</a
          >
          <a
            href={translatePath("/gallery")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.gallery")}</a
          >
          <a
            href={translatePath("/schedule")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.schedule")}</a
          >
          <a
            href={translatePath("/faqs")}
            class="text-sm tracking-widest text-gray-500 hover:text-[#c4917c] transition-colors"
            >{t("nav.faqs")}</a
          >
        </nav>

        <p class="credits text-xs text-gray-400">josealeysansta@email.com</p>
      </footer>
    </main>
  </div>
</Layout>
