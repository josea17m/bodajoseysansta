---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Jose Ale & Sansta - 24 de Julio, 2026">
  <header class="header">
    <button class="menu-btn" aria-label="Menú">
      <svg
        viewBox="0 0 24 24"
        width="24"
        height="24"
        stroke="currentColor"
        stroke-width="2"
        fill="none"
        class="menu-icon">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </header>

  <section class="hero-carousel" id="heroCarousel">
    <div
      class="carousel-slide active"
      style="background-image: url('/images/venue.png')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('/images/ring.png')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1519225421980-715cb0215aed?q=80&w=2000&auto=format&fit=crop')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1511285560929-80b456fea0bc?q=80&w=2000&auto=format&fit=crop')">
    </div>
    <div
      class="carousel-slide"
      style="background-image: url('https://images.unsplash.com/photo-1520854221256-17451cc331bf?q=80&w=2000&auto=format&fit=crop')">
    </div>
  </section>

  <main class="content">
    <section class="names-section">
      <h1 class="names">
        <span class="name">JOSE ALE</span>
        <span class="ampersand">&amp;</span>
        <span class="name">SANSTA</span>
      </h1>

      <h2 class="date">24 DE JULIO, 2026</h2>
      <p class="location-short">Houston & Richmond, TX</p>

      <div class="countdown" id="countdown">
        <!-- Javascript will populate this -->
      </div>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <section class="venue-section">
      <h3 class="section-title">CEREMONIA</h3>
      <p class="venue-name">Salón del Reino de Los Testigos de Jehová</p>
      <p class="venue-address">
        19220 Beechnut St Hall A<br />Richmond, TX 77407
      </p>

      <div style="height: 40px;"></div>

      <h3 class="section-title">RECEPCIÓN</h3>
      <p class="venue-name">The Juliana</p>
      <p class="venue-address">1001 W 18th St<br />Houston, TX 77008</p>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>

    <section class="story-section">
      <h3 class="section-title">NUESTRA HISTORIA</h3>
      <div class="story-text">
        <p>
          Nuestra historia comenzó un día inesperado. Nos conocimos rodeados de
          amigos y risas...
        </p>
        <p>
          El tiempo pasó volando y nos dimos cuenta de que no podíamos imaginar
          la vida el uno sin el otro...
        </p>
      </div>
    </section>

    <div class="separator">
      <svg
        viewBox="0 0 40 40"
        width="40"
        height="40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg">
        <path
          d="M12 28 C 15 20, 25 15, 30 10 C 27 18, 20 23, 15 28 Z"
          fill="#758B70"></path>
        <path
          d="M12 28 C 8 22, 12 14, 18 10 C 18 18, 14 24, 12 28 Z"
          fill="#8CA486"></path>
      </svg>
    </div>
  </main>

  <footer class="mini-footer">
    <div class="heart-logo">
      <span class="names-logo">J&S</span>
      <svg
        viewBox="0 0 40 20"
        width="30"
        height="15"
        fill="none"
        stroke="var(--text-accent)"
        stroke-width="2"
        style="margin-left: 5px;">
        <path d="M10 10 A5 5 0 1 1 20 10 A5 5 0 1 1 30 10 A5 5 0 1 1 10 10"
        ></path>
      </svg>
    </div>


    <nav class="footer-nav">
      <a href="/">Galeria</a>
      <a href="/faqs">Preguntas Frecuentes</a>
      <a href="/schedule">Itinerario</a>
      <a href="/registry">Mesa de Regalos</a>
    </nav>

    <p class="credits">josealeysansta@email.com</p>
  </footer>
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const countdownElement = document.getElementById("countdown");
    if (!countdownElement) return;

    // July 24, 2026 at 15:30 (3:30 PM)
    const weddingDate = new Date("2026-07-24T15:30:00").getTime();

    // Carousel Logic
    const slides = document.querySelectorAll(".carousel-slide");
    if (slides.length > 0) {
      let currentSlide = 0;
      setInterval(() => {
        if (slides[currentSlide]) {
          slides[currentSlide].classList.remove("active");
        }
        currentSlide = (currentSlide + 1) % slides.length;
        if (slides[currentSlide]) {
          slides[currentSlide].classList.add("active");
        }
      }, 4000); // Change image every 4 seconds
    }

    function updateCountdown() {
      const now = new Date().getTime();
      const distance = weddingDate - now;

      if (!countdownElement) return;

      if (distance < 0) {
        countdownElement.innerHTML = "¡Es el gran día!";
        return;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor(
        (distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60),
      );
      const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
      const seconds = Math.floor((distance % (1000 * 60)) / 1000);

      countdownElement.innerHTML = `
                <span><span class="time-val">${days}</span> d</span>
                <span><span class="time-val">${hours}</span> h</span>
                <span><span class="time-val">${minutes}</span> min</span>
                <span><span class="time-val">${seconds}</span> s</span>
            `;
    }

    setInterval(updateCountdown, 1000);
    updateCountdown();
  });
</script>

<style>
  /* Hero Carousel */
  .hero-carousel {
    position: relative;
    width: 100vw;
    height: 45vh;
    max-height: 500px;
    overflow: hidden;
  }

  .carousel-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
    z-index: 1;
  }

  .carousel-slide.active {
    opacity: 1;
    z-index: 2;
  }

  /* Main Content Wrapper */
  .content {
    max-width: 600px;
    margin: 0 auto;
    padding: 60px 20px;
    text-align: center;
  }

  /* Names Section */
  .names-section {
    margin-bottom: 50px;
  }

  .names {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 2.8rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    line-height: 1.4;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 25px;
  }

  .ampersand {
    font-size: 1.2rem;
    margin: 15px 0;
  }

  .hashtag {
    font-family: var(--font-heading);
    font-style: italic;
    color: var(--text-meta);
    font-size: 1.2rem;
    margin-bottom: 40px;
  }

  .date {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.6rem;
    letter-spacing: 0.18em;
    margin-bottom: 20px;
  }

  .location-short {
    font-size: 0.95rem;
    color: var(--text-primary);
    margin-bottom: 35px;
    letter-spacing: 0.05em;
  }

  .countdown {
    font-size: 0.95rem;
    color: var(--text-meta);
    letter-spacing: 0.05em;
    display: flex;
    justify-content: center;
    gap: 20px;
  }

  .countdown :global(span) {
    display: flex;
    align-items: baseline;
    gap: 5px;
  }

  .countdown :global(.time-val) {
    font-weight: 500;
  }

  /* Separator */
  .separator {
    text-align: center;
    margin: 50px 0;
  }

  .separator svg {
    margin: 0 auto;
  }

  /* Generic Section Styles */
  .section-title {
    font-family: var(--font-heading);
    color: var(--text-accent);
    font-size: 1.4rem;
    letter-spacing: 0.25em;
    margin-bottom: 25px;
    text-transform: uppercase;
  }

  /* Venue Section */
  .venue-name {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 12px;
  }

  .venue-address {
    color: var(--text-meta);
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Story Section */
  .story-text {
    color: var(--text-primary);
    font-size: 1rem;
    line-height: 1.9;
    text-align: justify;
    max-width: 500px;
    margin: 0 auto;
  }

  .story-text p {
    margin-bottom: 25px;
  }

  /* Base footer replacement for inner pages */
  .mini-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    padding: 40px 20px 60px;
    border-top: 1px solid #eee;
  }

  .heart-logo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .names-logo {
    font-family: "Inter", sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: 0.1em;
    color: var(--text-primary);
  }

  .tagline {
    font-size: 0.85rem;
    color: var(--text-meta);
  }

  .footer-nav {
    display: flex;
    gap: 15px;
    justify-content: center;
    margin: 10px 0;
  }

  .footer-nav a {
    color: var(--text-primary);
    text-decoration: none;
    font-size: 0.85rem;
  }

  .credits,
  .copyright {
    font-size: 0.75rem;
    color: var(--text-meta);
  }
</style>
